# ─── OpenClaw Environment Config ─────────────────────────────────────────────
# Copy this file to .env and fill in your keys

# ── Option 1: Groq (RECOMMENDED - 100% Free, fastest)
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Option 2: OpenRouter (Free models available)
# Get free key at: https://openrouter.ai
# OPENROUTER_API_KEY=your_openrouter_key_here

# ── Option 3: Ollama (Fully local, no key needed)
# Install: https://ollama.com  then run: ollama pull llama3
# No config needed — auto-detected if running on localhost:11434
