{
  "name": "openclaw-backend",
  "version": "1.0.0",
  "description": "OpenClaw AI Crypto Wallet Scanner - Backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm --prefix ../frontend run dev\"",
    "start:all": "concurrently \"npm start\" \"npm --prefix ../frontend start\""
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.2"
  }
}
